# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# xAI
XAI_API_KEY=your-xai-api-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# Google Gemini (analytics SQL agent)
GOOGLE_API_KEY=your-google-api-key-here

# Direct Postgres connection for analytics SQL agent
# Local dev (supabase start): postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Production: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
